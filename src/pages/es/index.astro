---
import { Image } from 'astro:assets';
import MainLayout from '../../layouts/MainLayout.astro';
import Gallery from '../../components/Gallery.astro';
import Blueprints from '../../components/Blueprints.astro';
import heroImage from '../../assets/hero-concrete.jpg';
---

<MainLayout title="ERICK VERA" lang="es">
	<!-- HERO SECTION -->
	<section id="home" class="hero-section">
		<div class="hero-bg">
			<Image 
				src={heroImage} 
				alt="Concrete Blocks Brutalist" 
				class="sculpture-img hero-img"
			/>
		</div>
		
		<div class="hero-content">
			<p class="mono-label hero-label">// SOFTWARE ARCHITECT. DESIGNER OF THOUGHT SYSTEMS.</p>
			<h1>ERICK VERA</h1>
			<p class="hero-quote">"Si la idea es robusta, el software es inevitable."</p>
		</div>
	</section>

	<!-- MANIFESTO GALLERY (IDENTITY SECTION) -->
	<Gallery lang="es" />

	<!-- BLUEPRINTS SECTION (DYNAMIC ARCHITECTURES) -->
	<Blueprints lang="es" />
</MainLayout>

<style>
  .hero-section {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    position: relative;
    overflow: hidden;
    padding-bottom: 10vh;
    z-index: 0;
  }

  .hero-bg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: -1;
    background: var(--bg-dark);
  }

  .hero-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.6;
    filter: grayscale(100%) contrast(120%) brightness(100%);
  }

  .hero-content {
    position: relative;
    z-index: 1;
    padding: 0 20px;
  }

  .hero-label {
    color: var(--accent-red);
    margin-bottom: 20px;
    word-break: break-word;
    white-space: normal;
  }

  .hero-quote {
    font-size: clamp(1.1rem, 4vw, 2rem);
    font-weight: 900;
    text-transform: uppercase;
    margin-top: 20px;
    word-break: break-word;
    white-space: normal;
    max-width: 100%;
  }

  @media (max-width: 768px) {
    .hero-content {
      padding: 0 15px;
    }
    .hero-label {
      font-size: 0.7rem;
      letter-spacing: 0.05em;
    }
  }
</style>
