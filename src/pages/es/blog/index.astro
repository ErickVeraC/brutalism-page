---
import { getCollection } from 'astro:content';
import MainLayout from '../../../layouts/MainLayout.astro';

const posts = (await getCollection('blog', ({ data }) => {
	return data.lang === 'es';
})).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<MainLayout title="ESTUDIO ABIERTO / LOG" lang="es">
	<section class="blog-archive">
		<div class="archive-header">
			<p class="mono-label accent-text">// LOG_DE_CONSTRUCCIÓN</p>
			<h1>ESTUDIO<br/>ABIERTO</h1>
			<p class="description mono-label">NOTAS SOBRE EXPERIENCIAS, DIVAGACIONES ESTÉTICAS Y ARQUITECTURAS LÓGICAS.</p>
		</div>

		<div class="posts-list">
			{posts.map((post, index) => (
				<a href={`/es/blog/${post.id}/`} class="post-item">
					<div class="post-index mono-label">[{String(index + 1).padStart(2, '0')}]</div>
					<div class="post-meta">
						<span class="pub-date mono-label">{post.data.pubDate.toLocaleDateString('es-ES', { year: 'numeric', month: '2-digit', day: '2-digit' })}</span>
						<h2 class="post-title">{post.data.title}</h2>
						<div class="post-tags">
							{post.data.tags.map(tag => (
								<span class="tag mono-label">#{tag}</span>
							))}
						</div>
					</div>
					<div class="post-arrow">→</div>
				</a>
			))}
		</div>

		{posts.length === 0 && (
			<div style="padding: 100px 0; text-align: center;">
				<p class="mono-label" style="opacity: 0.5;">// NO_POSTS_FOUND_IN_THIS_LOG</p>
			</div>
		)}
	</section>
</MainLayout>

<style>
	.blog-archive {
		padding: 120px 40px 80px 40px !important;
		background: var(--bg-dark);
		min-height: 100vh;
	}

	.archive-header {
		margin-bottom: 80px;
		border-bottom: var(--border-main);
		padding-bottom: 40px;
	}

	.accent-text { color: var(--accent-red); margin-bottom: 10px; }
	.description { opacity: 0.6; margin-top: 20px; max-width: 600px; line-height: 1.4; }

	.posts-list {
		display: flex;
		flex-direction: column;
	}

	.post-item {
		display: grid;
		grid-template-columns: 80px 1fr 50px;
		align-items: center;
		padding: 40px 0;
		border-bottom: 1px solid rgba(255, 255, 255, 0.1);
		text-decoration: none;
		color: var(--text-main);
		transition: all 0.3s ease;
	}

	.post-item:hover {
		background: rgba(255, 255, 255, 0.02);
		padding-left: 20px;
		padding-right: 20px;
		border-bottom-color: var(--accent-red);
	}

	.post-item:hover .post-title {
		color: var(--accent-red);
	}

	.post-index {
		color: var(--accent-red);
		font-weight: bold;
	}

	.post-title {
		font-size: clamp(1.5rem, 3vw, 3rem);
		font-weight: 900;
		text-transform: uppercase;
		line-height: 1;
		margin: 10px 0;
		transition: color 0.3s ease;
	}

	.pub-date {
		opacity: 0.5;
		font-size: 0.8rem;
	}

	.post-tags {
		display: flex;
		gap: 15px;
		margin-top: 10px;
	}

	.tag {
		font-size: 0.7rem;
		opacity: 0.4;
	}

	.post-arrow {
		font-size: 2rem;
		opacity: 0;
		transform: translateX(-20px);
		transition: all 0.3s ease;
		color: var(--accent-red);
	}

	.post-item:hover .post-arrow {
		opacity: 1;
		transform: translateX(0);
	}

	@media (max-width: 768px) {
		.post-item {
			grid-template-columns: 50px 1fr;
		}
		.post-arrow { display: none; }
		.post-title { font-size: 1.5rem; }
	}
</style>
