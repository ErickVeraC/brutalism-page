---
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import MainLayout from '../../../layouts/MainLayout.astro';

export async function getStaticPaths() {
	const blogEntries = await getCollection('blog');
	return blogEntries.map(entry => ({
		params: { slug: entry.id }, props: { entry },
	}));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

// Resolve dynamic image path for production optimization
const images = import.meta.glob<{ default: any }>('/src/assets/*.{jpeg,jpg,png,gif,webp,avif}');
const heroImagePath = entry.data.heroImage;

const imageImport = heroImagePath ? images[heroImagePath] : null;
const imageSrc = imageImport ? (await imageImport()).default : null;
---

<MainLayout title={entry.data.title} lang={entry.data.lang}>
	<article class="post-article">
		
		<!-- CABECERA CONTROLADA -->
		<div class="post-header">
			<div class="post-meta mono-label">
				<span class="accent-text">// REGISTRO: {entry.data.pubDate.toLocaleDateString('es-ES')}</span>
				<div class="tags-row">
					{entry.data.tags.map((tag: string) => (
						<span class="tag">#{tag}</span>
					))}
				</div>
			</div>
			<h1 class="post-title">{entry.data.title}</h1>
			<p class="excerpt">{entry.data.description}</p>
		</div>

		<!-- IMAGEN HERO OPTIMIZADA -->
		{imageSrc ? (
			<div class="hero-container">
				<Image src={imageSrc} alt={entry.data.title} class="sculpture-img" />
			</div>
		) : entry.data.heroImage ? (
			<div class="hero-container">
				<img src={entry.data.heroImage} alt={entry.data.title} class="sculpture-img" />
			</div>
		) : null}

		<!-- CUERPO DE LECTURA -->
		<div class="markdown-body">
			<Content />
		</div>

		<!-- FOOTER DE NAVEGACIÓN -->
		<div class="post-footer">
			<a href="/es/blog/" class="mono-label back-link">← [ VOLVER_AL_LOG ]</a>
		</div>

	</article>
</MainLayout>

<style>
	.post-article {
		display: block; /* Rompe cualquier contexto flex/grid heredado del layout padre */
		max-width: 900px; /* Ancho máximo ideal para lectura y contención de UI */
		margin: 0 auto;
		padding: 160px 24px 80px 24px !important; /* Padding lateral base para mobile */
		background: var(--bg-dark);
	}

	.post-header {
		margin-bottom: 60px;
		border-bottom: var(--border-main);
		padding-bottom: 40px;
	}

	.post-meta {
		display: flex;
		flex-wrap: wrap;
		gap: 20px;
		font-size: 0.8rem;
		margin-bottom: 20px;
	}

	.accent-text { color: var(--accent-red); }
	.tag { opacity: 0.5; }

	.post-title {
		font-size: clamp(2rem, 8vw, 4.5rem); /* Tamaño masivo pero contenido */
		line-height: 0.9;
		text-transform: uppercase;
		word-wrap: break-word; /* Seguridad ante desbordamiento */
		margin: 0;
	}

	.excerpt {
		font-size: clamp(1.1rem, 2vw, 1.5rem);
		font-weight: 300;
		opacity: 0.8;
		margin-top: 30px;
		line-height: 1.3;
	}

	.hero-container {
		width: 100%;
		border: var(--border-main);
		margin-bottom: 60px;
		overflow: hidden;
		max-height: 50vh; /* Alto de banner dinámico */
		min-height: 300px;
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.hero-container img {
		width: 100%;
		height: 100%;
		display: block;
		object-fit: cover;
	}

	/* Estilos de Lectura Progresiva */
	.markdown-body {
		font-family: var(--font-primary);
		font-size: 1.25rem;
		line-height: 1.6;
		color: var(--text-muted);
	}

	.markdown-body :global(h2) {
		font-size: clamp(1.8rem, 4vw, 2.5rem);
		color: var(--text-main);
		margin: 60px 0 30px 0;
		text-transform: uppercase;
		border-left: 5px solid var(--accent-red);
		padding-left: 20px;
	}

	.markdown-body :global(p) {
		margin-bottom: 30px;
	}

	.markdown-body :global(strong) {
		color: var(--text-main);
		font-weight: 900;
	}

	.post-footer {
		margin-top: 100px;
		padding-top: 40px;
		border-top: var(--border-main);
	}

	.back-link {
		text-decoration: none;
		color: var(--accent-red);
		font-weight: bold;
		transition: all 0.3s ease;
	}

	.back-link:hover {
		color: var(--text-main);
	}

	/* Desktop Adjustments */
	@media (min-width: 768px) {
		.post-article {
			padding-left: 40px !important;
			padding-right: 40px !important;
		}
	}
</style>
