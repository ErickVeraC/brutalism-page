---
import { Image } from 'astro:assets';

// Importación de imágenes (Astro las procesa y optimiza)
import img1 from '../assets/Camisa de vestir blanca.jpg';
import img2 from '../assets/Ramo de rosas blancas.jpg';
import img3 from '../assets/Estructura triangular sobre rejilla.jpg';
import img4 from '../assets/Estatua hombre desnudo.jpg';
import img5 from '../assets/Ventanas góticas iluminadas.jpg';

const images = [
  { src: img1, alt: 'White Shirt Texture', grid: 'span 2 / span 1', clip: 'polygon(0 0, 100% 0, 100% 70%, 0% 100%)' },
  { src: img2, alt: 'White Roses Brutal', grid: 'span 1 / span 1', clip: 'polygon(20% 0%, 100% 0%, 80% 100%, 0% 100%)' },
  { src: img3, alt: 'Triangular Structure', grid: 'span 1 / span 2', clip: 'inset(10% 0 10% 0)' },
  { src: img4, alt: 'Nude Statue Detail', grid: 'span 2 / span 1', clip: 'polygon(0 15%, 100% 0, 100% 100%, 0 85%)' },
  { src: img5, alt: 'Gothic Windows', grid: 'span 1 / span 1', clip: 'polygon(0 0, 100% 20%, 100% 100%, 0 80%)' },
];
---

<section class="gallery-brutal">
  <div class="gallery-grid">
    {images.map((img) => (
      <div class="img-container" style={`grid-area: ${img.grid}; clip-path: ${img.clip};`}>
        <Image 
          src={img.src} 
          alt={img.alt} 
          class="sculpture-img"
          width={800}
          height={1000}
        />
        <div class="img-overlay">
          <span class="mono-label" style="font-size: 0.6rem; opacity: 0.7;">[ {img.alt.toUpperCase().replace(/ /g, '_')} ]</span>
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  .gallery-brutal {
    padding: 0 !important;
    background: var(--bg-dark);
    overflow: hidden;
    border-bottom: var(--border-main);
  }

  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    grid-auto-rows: 300px;
    gap: 0;
    border-left: var(--border-main);
    border-right: var(--border-main);
  }

  .img-container {
    position: relative;
    border: 1px solid rgba(255, 255, 255, 0.1);
    background: #000;
    transition: transform 0.4s cubic-bezier(0.23, 1, 0.32, 1);
    filter: sepia(100%) hue-rotate(320deg) saturate(150%) brightness(0.7); /* Punk feel */
  }

  .img-container:hover {
    filter: grayscale(100%) contrast(150%) brightness(1);
    transform: scale(1.05) rotate(1deg);
    z-index: 10;
  }

  .img-container :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .img-overlay {
    position: absolute;
    bottom: 10px;
    left: 10px;
    background: var(--accent-red);
    color: var(--bg-dark);
    padding: 2px 8px;
    pointer-events: none;
  }

  @media (max-width: 768px) {
    .gallery-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
