---
import { Image } from 'astro:assets';

// Importación de imágenes
import img1 from '../assets/Camisa de vestir blanca.jpg';
import img2 from '../assets/Ramo de rosas blancas.jpg';
import img4 from '../assets/Estatua hombre desnudo.jpg';
import img5 from '../assets/Ventanas góticas iluminadas.jpg';

const { lang = 'es' } = Astro.props;

const texts = {
  es: "No pico código; diseño sistemas de pensamiento. Mi valor no es la ejecución perfunctoria, sino la arquitectura lógica previa. En mi mesa, la estructura dicta la sintaxis.",
  en: "I don't just write code; I design systems of thought. My value is not perfunctory execution, but prior logical architecture. On my desk, structure dictates syntax.",
  pt: "Não apenas escrevo código; desenho sistemas de pensamento. Meu valor não é a execução perfunctória, mas a arquitetura lógica prévia. Na minha mesa, a estrutura dita a sintaxe."
};
---

<section class="gallery-manifesto" id="manifesto">

  <!-- TÍTULO DESBORDADO (EL CENTRO) -->
  <div class="overflow-title-container">
    <h2 class="manifesto-title-massive">THE MANIFEST</h2>
  </div>

  <div class="gallery-grid">

    <!-- 01: IMAGEN (CAMISA) -->
    <div class="grid-item img-container clip-1">
      <Image src={img1} alt="Texture 01" class="sculpture-img" width={800} />
    </div>

    <!-- 02: BLOQUE VACÍO -->
    <div class="grid-item grid-item--dark empty-block">
      <div class="serigrafia-overlay"></div>
    </div>

    <!-- 03: IMAGEN (ESTATUA) -->
    <div class="grid-item img-container clip-2">
      <Image src={img4} alt="Statue Logic" class="sculpture-img" width={800} />
    </div>

    <!-- 04: IMAGEN (ROSAS) -->
    <div class="grid-item img-container clip-3">
      <Image src={img2} alt="Roses Brutal" class="sculpture-img" width={800} />
    </div>

    <!-- 05: TEXTO (BODY) -->
    <div class="grid-item text-block body-block clip-4 grid-item--dark">
      <div class="serigrafia-overlay"></div>
      <p class="mono-label gallery-accent-label">// ARCHITECT_VALUE</p>
      <h2 class="manifesto-body">{texts[lang]}</h2>
    </div>

    <!-- 06: IMAGEN (VENTANAS) -->
    <div class="grid-item img-container clip-3">
      <Image src={img5} alt="Gothic Windows" class="sculpture-img" width={800} />
    </div>

  </div>
</section>
