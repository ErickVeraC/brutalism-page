---
import { Image } from 'astro:assets';

// Importación de imágenes
import img1 from '../assets/Camisa de vestir blanca.jpg';
import img2 from '../assets/Ramo de rosas blancas.jpg';
import img4 from '../assets/Estatua hombre desnudo.jpg';
import img5 from '../assets/Ventanas góticas iluminadas.jpg';

const { lang = 'es' } = Astro.props;

const texts = {
  es: "No pico código; diseño sistemas de pensamiento. Mi valor no es la ejecución perfunctoria, sino la arquitectura lógica previa. En mi mesa, la estructura dicta la sintaxis.",
  en: "I don't just write code; I design systems of thought. My value is not perfunctory execution, but prior logical architecture. On my desk, structure dictates syntax.",
  pt: "Não apenas escrevo código; desenho sistemas de pensamento. Meu valor não é a execução perfunctória, mas a arquitetura lógica prévia. Na minha mesa, a estrutura dita a sintaxe."
};
---

<section class="gallery-manifesto" id="manifesto">
  
  <!-- TÍTULO DESBORDADO (EL CENTRO) -->
  <div class="overflow-title-container">
    <h2 class="manifesto-title-massive">THE MANIFEST</h2>
  </div>

  <div class="gallery-grid">
    
    <!-- 01: IMAGEN (CAMISA) -->
    <div class="grid-item img-container" style="clip-path: polygon(0 0, 100% 0, 80% 100%, 0% 100%);">
      <Image src={img1} alt="Texture 01" class="sculpture-img" width={800} />
    </div>

    <!-- 02: BLOQUE VACÍO (ESPACIO PARA EL TÍTULO QUE FLOTA ARRIBA) -->
    <div class="grid-item empty-block" style="background: #050505; border-bottom: var(--border-main);">
      <div class="serigrafia-overlay"></div>
    </div>

    <!-- 03: IMAGEN (ESTATUA) -->
    <div class="grid-item img-container" style="clip-path: polygon(0 0, 100% 0, 100% 80%, 20% 100%);">
      <Image src={img4} alt="Statue Logic" class="sculpture-img" width={800} />
    </div>

    <!-- 04: IMAGEN (ROSAS) -->
    <div class="grid-item img-container" style="clip-path: polygon(0 20%, 100% 0, 100% 100%, 0 100%);">
      <Image src={img2} alt="Roses Brutal" class="sculpture-img" width={800} />
    </div>

    <!-- 05: TEXTO (BODY) -->
    <div class="grid-item text-block body-block" style="clip-path: polygon(0 0, 80% 0, 100% 100%, 0 80%); background: #050505;">
      <div class="serigrafia-overlay"></div>
      <p class="mono-label" style="color: var(--accent-red); margin-bottom: 20px;">// ARCHITECT_VALUE</p>
      <h2 class="manifesto-body">{texts[lang]}</h2>
    </div>

    <!-- 06: IMAGEN (VENTANAS) -->
    <div class="grid-item img-container" style="clip-path: polygon(20% 0, 100% 20%, 100% 100%, 0 100%);">
      <Image src={img5} alt="Gothic Windows" class="sculpture-img" width={800} />
    </div>

  </div>
</section>

<style>
  .gallery-manifesto {
    padding: 0 !important;
    background: var(--bg-dark);
    border-top: var(--border-main);
    position: relative; /* Contexto para el título absoluto */
  }

  /* Contenedor del Título que se desborda */
  .overflow-title-container {
    position: absolute;
    top: 200px; /* Centrado vertical aproximado en la primera fila */
    left: 50%;
    transform: translateX(-50%);
    width: 100vw;
    text-align: center;
    z-index: 100; /* Por encima de todo */
    pointer-events: none;
  }

  .manifesto-title-massive {
    font-family: var(--font-primary);
    font-weight: 900;
    font-size: clamp(5rem, 15vw, 20rem); /* GIGANTE */
    line-height: 0.8;
    text-transform: uppercase;
    color: var(--text-main);
    text-shadow: 8px 8px 0px var(--accent-red);
    margin: 0;
    white-space: nowrap;
    letter-spacing: -0.05em;
    mix-blend-mode: difference; /* Para que interactúe con las imágenes de fondo */
  }

  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    grid-auto-rows: minmax(500px, auto);
    gap: 0;
  }

  .grid-item {
    position: relative;
    background: #000;
    overflow: hidden;
    border: 0.5px solid rgba(255,255,255,0.1);
  }

  .text-block {
    padding: 80px 40px;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .serigrafia-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-image: radial-gradient(circle, rgba(255,255,255,0.1) 1.5px, transparent 1.5px);
    background-size: 6px 6px;
    z-index: 1;
  }

  .manifesto-body {
    font-family: var(--font-primary);
    font-weight: 900;
    font-size: clamp(1.5rem, 3vw, 4rem);
    line-height: 0.9;
    text-transform: uppercase;
    color: var(--text-main);
    z-index: 2;
    margin: 0;
    letter-spacing: -0.02em;
  }

  .img-container {
    filter: sepia(100%) hue-rotate(320deg) saturate(150%) brightness(0.6);
    transition: all 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .img-container:hover {
    filter: grayscale(100%) contrast(150%) brightness(0.9);
    transform: scale(1.05);
    z-index: 10;
  }

  .img-container :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .manifesto-title-massive {
      font-size: 18vw;
    }
    .gallery-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .overflow-title-container {
      top: 100px;
    }
    .gallery-grid {
      grid-template-columns: 1fr;
    }
    .grid-item {
      clip-path: none !important;
      min-height: 400px;
    }
    .manifesto-title-massive {
      font-size: 20vw;
    }
  }
</style>
