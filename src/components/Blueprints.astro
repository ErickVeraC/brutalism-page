const content = blueprintTexts[lang];
---

<section id="blueprints" class="blueprints-section">
  <div class="header-blueprints">
    <p class="mono-label accent-text">{content.title}</p>
    <h2>{content.subtitle}</h2>
    <p class="description mono-label">{content.description}</p>
  </div>

  <div class="command-center">
    <!-- Navegación lateral -->
    <nav class="blueprint-nav">
      {content.scenarios.map((s, index) => (
        <button
          class={`nav-item ${index === 0 ? 'active' : ''}`}
          data-id={s.id}
        >
          <span class="index">[{String(index + 1).padStart(2, '0')}]</span>
          <span class="label">{s.label}</span>
        </button>
      ))}
    </nav>

    <!-- Visualizador central -->
    <div class="display-area">
      {content.scenarios.map((s, index) => (
        <div
          id={`content-${s.id}`}
          class={`blueprint-content ${index === 0 ? 'visible' : ''}`}
        >
          <div class="blueprint-info">
            <p class="blueprint-summary">{s.summary}</p>
          </div>

          <div class="stack-grid">
            {s.stack.map(tech => (
              <div class="tech-card">
                <div class="tech-icon-placeholder">
                  <span class="mono-label">{tech.substring(0, 2).toUpperCase()}</span>
                </div>
                <span class="tech-label mono-label">{tech}</span>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  function initBlueprints() {
    const navItems = document.querySelectorAll('.nav-item');
    const contents = document.querySelectorAll('.blueprint-content');

    navItems.forEach(item => {
      item.addEventListener('click', () => {
        const targetId = (item as HTMLElement).dataset.id;

        navItems.forEach(nav => nav.classList.remove('active'));
        item.classList.add('active');

        contents.forEach(content => {
          content.classList.remove('visible');
          if (content.id === `content-${targetId}`) {
            content.classList.add('visible');
          }
        });
      });
    });
  }

  document.addEventListener('DOMContentLoaded', initBlueprints);
</script>
