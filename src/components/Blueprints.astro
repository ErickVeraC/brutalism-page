      }
    ]
  },
  pt: {
    title: "// TECH_BLUEPRINTS",
    subtitle: "SISTEMAS DE ALTA PRECISÃO",
    description: "Cada arquitetura é uma resposta lógica a um problema de negócio. Selecione uma para ver a stack recomendada.",
    scenarios: [
      {
        id: "landing",
        label: "01_LANDING / CONTENT FIRST",
        summary: "Focado em Core Web Vitals, SEO e velocidade máxima de carregamento estático.",
        stack: ["Astro v6", "Vanilla CSS", "Vercel / AWS Amplify", "Google Tag Manager", "GitHub Actions"]
      },
      {
        id: "saas",
        label: "02_SCALABLE SAAS / WEB APP",
        summary: "Arquitetura moderna para aplicações interactivas com tipos seguros e implementação rápida.",
        stack: ["Next.js / React", "Hono / Node.js", "PostgreSQL (Prisma/Drizzle)", "Auth.js / Clerk", "Terraform"]
      },
      {
        id: "highperf",
        label: "03_HIGH PERFORMANCE / EVENT-DRIVEN",
        summary: "Sistemas distribuídos para processamento maciço de datos e baixa latência.",
        stack: ["Go / Python", "Kafka / RabbitMQ", "MongoDB / TimescaleDB", "Kubernetes (K8s)", "AWS EKS / EC2"]
      },
      {
