        stack: ["Next.js (ISR)", "Stripe / Adyen", "Algolia Search", "Redis Cache", "Vercel Edge Functions"]
      },
      {
        id: "admin",
        label: "05_ADMIN / INVENTORY CONTROL",
        summary: "Sistemas internos robustos con alta integridad de datos y gestión compleja de recursos.",
        stack: ["Angular Dashboard", "Node.js API", "PostgreSQL (ACID)", "Docker", "AWS RDS / S3"]
      }
    ]
  },
  en: {
    title: "// TECH_BLUEPRINTS",
    subtitle: "HIGH PRECISION SYSTEMS",
    description: "Each architecture is a logical response to a business problem. Select one to see the recommended stack.",
    scenarios: [
      {
        id: "landing",
        label: "01_LANDING / CONTENT FIRST",
        summary: "Focused on Core Web Vitals, SEO, and maximum static loading speed.",
        stack: ["Astro v6", "Vanilla CSS", "Vercel / AWS Amplify", "Google Tag Manager", "GitHub Actions"]
      },
      {
        id: "saas",
        label: "02_SCALABLE SAAS / WEB APP",
        summary: "Modern architecture for interactive applications with safe types and fast deployment.",
        stack: ["Next.js / React", "Hono / Node.js", "PostgreSQL (Prisma/Drizzle)", "Auth.js / Clerk", "Terraform"]
      },
      {
        id: "highperf",
        label: "03_HIGH PERFORMANCE / EVENT-DRIVEN",
        summary: "Distributed systems for massive data processing and low latency.",
        stack: ["Go / Python", "Kafka / RabbitMQ", "MongoDB / TimescaleDB", "Kubernetes (K8s)", "AWS EKS / EC2"]
      },
      {
        id: "ecommerce",
        label: "04_E-COMMERCE / HIGH CONVERSION",
        summary: "Sales platforms optimized for conversion, speed, and global scalability.",
        stack: ["Next.js (ISR)", "Stripe / Adyen", "Algolia Search", "Redis Cache", "Vercel Edge Functions"]
      },
      {
