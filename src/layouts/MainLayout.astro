---
import '../styles/global.css';

interface Props {
	title: string;
	lang: 'es' | 'en' | 'pt';
}

const { title, lang } = Astro.props;

const navItems = [
	{ label: '/01_MANIFESTO', href: `/${lang}/#manifesto` },
	{ label: '/02_BLUEPRINTS', href: `/${lang}/#blueprints` },
	{ label: '/03_LOG', href: `/es/blog/` },
	{ label: '/04_CONTACT', href: `/${lang}/#contact` },
];

const languages = [
	{ code: 'es', label: 'ES' },
	{ code: 'en', label: 'EN' },
	{ code: 'pt', label: 'PT' },
];
---

<!doctype html>
<html lang={lang}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<title>{title} | Erick Vera</title>
	</head>
	<body>
		<header>
			<div class="brand mono-label">
				<a href={`/${lang}/`}>erickvcoder.codes</a>
			</div>
			
			<nav class="desktop-nav">
				{navItems.map(item => (
					<a href={item.href} class="mono-label">{item.label}</a>
				))}
			</nav>

			<div class="lang-selector mono-label">
				[ {languages.map((l, i) => (
					<>
						<a href={`/${l.code}/`} class={lang === l.code ? 'active' : ''}>{l.label}</a>
						{i < languages.length - 1 && ' / '}
					</>
				))} ]
			</div>
		</header>
		
		<main>
			<slot />
		</main>

		<footer>
			<div class="footer-content">
				<h1 style="color: var(--bg-dark); font-size: 8vw;">READY TO BUILD<br/>WITH LOGIC?</h1>
				
				<div class="footer-actions" style="margin-top: 40px;">
					<a href="https://www.upwork.com/freelancers/~01638bc46d04e16563" class="brutal-card" style="background: var(--bg-dark); color: var(--text-main); display: inline-block; text-decoration: none; font-family: var(--font-mono);">
						[ HIRE_ON_UPWORK ]
					</a>
				</div>

				<div class="footer-meta mono-label" style="margin-top: 80px; display: flex; justify-content: space-between; border-top: 2px solid var(--bg-dark); padding-top: 20px; flex-wrap: wrap; gap: 20px;">
					<div style="display: flex; gap: 30px; align-items: center;">
						<a href="https://github.com/ErickVeraC" target="_blank" rel="noopener noreferrer" style="color: var(--bg-dark); text-decoration: none; display: flex; align-items: center; gap: 8px;">
							<svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.042-1.416-4.042-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
							GITHUB
						</a>
						<a href="https://www.linkedin.com/in/erickvcoder" target="_blank" rel="noopener noreferrer" style="color: var(--bg-dark); text-decoration: none; display: flex; align-items: center; gap: 8px;">
							<svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
							LINKEDIN
						</a>
					</div>
					<div>LOCATION: MEXICO_CITY // TLAXCALA</div>
				</div>
			</div>
		</footer>
	</body>
</html>
